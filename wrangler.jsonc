{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rhr-tv-worker",
  "main": "worker.ts",
  "compatibility_date": "2024-03-20",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "ZAP_CACHE",
      "id": "REPLACE_WITH_KV_ID_AFTER_CREATION"
    }
  ],
  "triggers": {
    "crons": [
      "*/10 * * * *" 
    ]
  },
  "observability": {
    "enabled": true
  }
}
